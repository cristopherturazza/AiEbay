{
  "name": "sellbot",
  "version": "0.1.0",
  "description": "CLI Node.js + TypeScript per pubblicare inserzioni eBay da cartelle locali",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sellbot": "dist/index.js",
    "sellbot-mcp": "dist/mcp/server.js",
    "sellbot-mcp-http": "dist/mcp/http-server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "mcp": "tsx src/mcp/server.ts",
    "mcp:http": "tsx src/mcp/http-server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "ebay",
    "cli",
    "typescript",
    "sell"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "ebay-oauth-nodejs-client": "^1.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/ebay-oauth-nodejs-client": "^1.2.4",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
