# Production credentials and defaults
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=

# Optional callback URL used only for local auto-capture mode.
# If omitted, `sellbot auth` asks you to paste the redirected URL/code manually.
EBAY_CALLBACK_URL=

# During initial production bootstrap you may temporarily add sell.account:
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account https://api.ebay.com/oauth/api_scope/sell.account.readonly
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account.readonly

# Production listing policies/location file
SELLBOT_CONFIG_FILE=sellbot.config.prod.json

# Account deletion notification compliance endpoint
SELLBOT_NOTIFICATION_ENDPOINT_URL=
SELLBOT_NOTIFICATION_VERIFICATION_TOKEN=

# Optional explicit overrides (normally auto-derived by EBAY_ENV)
# Note: with official eBay OAuth SDK, auth endpoint follows EBAY_ENV.
# EBAY_AUTH_BASE_URL=https://auth.ebay.com
# EBAY_API_BASE_URL=https://api.ebay.com
# EBAY_MEDIA_BASE_URL=https://apim.ebay.com
