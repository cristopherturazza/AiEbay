# Sandbox credentials and defaults
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=

# Optional public/local callback URL served by `sellbot mcp:http`.
# Example: http://localhost:3000/auth/ebay/callback
# If omitted, only the legacy manual `sellbot_auth_complete` / `sellbot auth` flow is available.
EBAY_CALLBACK_URL=

# Required scopes for this project:
# - sell.inventory: inventory item + offer + publish offer
# - sell.account.readonly: read-only policy checks in config:test
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account.readonly

# Optional config file path for sandbox listing policies/location
SELLBOT_CONFIG_FILE=sellbot.config.sandbox.json

# Optional explicit overrides (normally auto-derived by EBAY_ENV)
# Note: with official eBay OAuth SDK, auth endpoint follows EBAY_ENV.
# EBAY_AUTH_BASE_URL=https://auth.sandbox.ebay.com
# EBAY_API_BASE_URL=https://api.sandbox.ebay.com
# EBAY_MEDIA_BASE_URL=https://apim.sandbox.ebay.com
