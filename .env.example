# Base env selector.
# `sellbot` loads, in order:
# 1) .env
# 2) .env.sandbox or .env.prod (based on EBAY_ENV)
# 3) SELLBOT_ENV_FILE if set
# 4) real shell environment variables
EBAY_ENV=sandbox

# Optional extra overlay file, relative to repo root or absolute.
# Example:
# SELLBOT_ENV_FILE=.env.prod.local
# SELLBOT_ENV_FILE=/Users/name/secure/sellbot.prod.env
SELLBOT_ENV_FILE=

# Default marketplace
EBAY_MARKETPLACE_ID=EBAY_IT

# Optional config file path (relative to repo root or absolute).
# Useful to separate sandbox/prod configs, e.g. sellbot.config.prod.json.
# SELLBOT_CONFIG_FILE=sellbot.config.sandbox.json

# Local bind port for `sellbot mcp:http` and fallback port for localhost callback URLs.
SELLBOT_PORT=3000

# eBay marketplace account deletion notification endpoint (production compliance)
# Usually only needed in production.
# Public HTTPS URL that eBay will call, e.g. via Cloudflare Tunnel or Tailscale Funnel.
SELLBOT_NOTIFICATION_ENDPOINT_URL=

# Verification token configured in eBay Notifications settings
SELLBOT_NOTIFICATION_VERIFICATION_TOKEN=

# ---- Vision provider (mastrota book identification) ----
# Provider per `sellbot_book_identify_from_photo` e per il flow
# `sellbot_listing_create_from_inbox`. Valori: "ollama" (default,
# self-hosted) | "openrouter" (cloud, OpenAI-compatible chat completions
# con immagini). Switch immediato cambiando solo questa env.
MASTROTA_VISION_PROVIDER=ollama

# ---- Ollama vision (provider=ollama) ----
# Base URL dell'istanza Ollama. Dai container dell'homelab TurazzAI usare
# http://host.docker.internal:11434; dal bare metal localhost va bene.
MASTROTA_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Modello di vision usato quando provider=ollama.
# Policy homelab: gemma4:e4b (128K context, input multimodale).
MASTROTA_OLLAMA_VISION_MODEL=gemma4:e4b

# keep_alive corto per evitare di sfrattare il modello testuale pinned
# (es. qwen2.5:3b-instruct con keep_alive=-1 sul baseline Telegram).
MASTROTA_OLLAMA_VISION_KEEP_ALIVE=60s

# Timeout singola chiamata vision in millisecondi (default 120s).
MASTROTA_OLLAMA_VISION_TIMEOUT_MS=120000

# ---- OpenRouter vision (provider=openrouter) ----
# Richiede MASTROTA_OPENROUTER_API_KEY (sk-or-...). Default model
# openai/gpt-4o-mini: ~2-5s per immagine, costo nell'ordine di frazioni
# di centesimo, accuratezza alta su copertine libri. Alternative valide:
# google/gemini-2.0-flash, anthropic/claude-haiku-4-5.
MASTROTA_OPENROUTER_API_KEY=
MASTROTA_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MASTROTA_OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
MASTROTA_OPENROUTER_VISION_TIMEOUT_MS=60000

# Best-practice headers per OpenRouter (visibili nei log della dashboard).
# Lascia vuoti per ometterli.
MASTROTA_OPENROUTER_HTTP_REFERER=
MASTROTA_OPENROUTER_X_TITLE=
