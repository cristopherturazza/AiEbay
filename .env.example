# eBay environment: sandbox | prod
EBAY_ENV=sandbox

# eBay application credentials (Developer Program)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Redirect URI configured in eBay developer app (for local callback flow)
EBAY_REDIRECT_URI=http://localhost:3000/callback

# Required scopes for this project:
# - sell.inventory: inventory item + offer + publish offer
# - sell.account.readonly: read-only policy checks in config:test
EBAY_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account.readonly

# Default marketplace
EBAY_MARKETPLACE_ID=eBay_IT

# Local callback server port fallback (used if redirect URI has no explicit port)
SELLBOT_PORT=3000

# Optional explicit overrides (normally auto-derived by EBAY_ENV)
# EBAY_AUTH_BASE_URL=https://auth.sandbox.ebay.com
# EBAY_API_BASE_URL=https://api.sandbox.ebay.com
# EBAY_MEDIA_BASE_URL=https://apim.sandbox.ebay.com
